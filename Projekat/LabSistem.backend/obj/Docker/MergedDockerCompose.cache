name: dockercompose11608637791991648671
services:
  db:
    container_name: labsistem-db
    environment:
      POSTGRES_DB: labsistem
      POSTGRES_PASSWORD: labsistem
      POSTGRES_USER: labsistem
    healthcheck:
      test:
        - CMD-SHELL
        - pg_isready -U labsistem -d labsistem
      timeout: 5s
      interval: 5s
      retries: 20
    image: postgres:16
    networks:
      default: null
    ports:
      - mode: ingress
        target: 5432
        published: "5432"
        protocol: tcp
    volumes:
      - type: volume
        source: labsistem_pgdata
        target: /var/lib/postgresql/data
        volume: {}
  labsistem.api:
    build:
      context: C:\Users\emina\SI\SI-TIM8\Projekat\LabSistem.backend
      dockerfile: LABsistem.Presentation/Dockerfile
    container_name: labsistem-api
    depends_on:
      db:
        condition: service_healthy
        required: true
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      ASPNETCORE_HTTPS_PORTS: "8081"
      ConnectionStrings__Default: Host=db;Port=5432;Database=labsistem;Username=labsistem;Password=labsistem
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        published: "8080"
        protocol: tcp
      - mode: ingress
        target: 8080
        protocol: tcp
      - mode: ingress
        target: 8081
        protocol: tcp
    volumes:
      - type: bind
        source: C:\Users\emina\AppData\Roaming/Microsoft/UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\emina\AppData\Roaming/Microsoft/UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\emina\AppData\Roaming/ASP.NET/Https
        target: /home/app/.aspnet/https
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\emina\AppData\Roaming/ASP.NET/Https
        target: /root/.aspnet/https
        read_only: true
        bind: {}
networks:
  default:
    name: dockercompose11608637791991648671_default
volumes:
  labsistem_pgdata:
    name: dockercompose11608637791991648671_labsistem_pgdata